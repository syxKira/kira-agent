{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kira-agent.local/schemas/skill-package.schema.json",
  "title": "SkillPackage",
  "type": "object",
  "required": ["skill_id", "name", "description", "source", "valid", "active", "workflows", "allowed_tools", "diagnostics"],
  "properties": {
    "skill_id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "when_to_use": { "type": ["string", "null"] },
    "invocation": {
      "type": "object",
      "properties": {
        "argument_hint": { "type": ["string", "null"] },
        "disable_model_invocation": { "type": "boolean" },
        "user_invocable": { "type": "boolean" },
        "model_invocable": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "required": ["key", "priority", "path"],
      "properties": {
        "key": { "type": "string" },
        "priority": { "type": "integer" },
        "path": { "type": "string" }
      },
      "additionalProperties": false
    },
    "valid": { "type": "boolean" },
    "active": { "type": "boolean" },
    "shadowed_by": { "type": ["string", "null"] },
    "body_loaded": { "type": "boolean" },
    "body": { "type": ["string", "null"] },
    "workflows": { "type": "array", "items": { "type": "object" } },
    "allowed_tools": { "type": "array", "items": { "type": "string" } },
    "permissions": { "type": "object" },
    "fixtures": { "type": "array", "items": { "type": "object" } },
    "references": { "type": "array", "items": { "type": "string" } },
    "context": { "type": "array", "items": { "type": "string" } },
    "ui": { "type": "object" },
    "model_hint": {
      "type": ["object", "null"],
      "properties": {
        "profile": { "type": ["string", "null"] },
        "model": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message", "severity"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "severity": { "type": "string", "enum": ["error", "warning", "info"] },
          "metadata": { "type": "object" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
