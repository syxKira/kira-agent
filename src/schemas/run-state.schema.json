{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kira-agent.local/schemas/run-state.schema.json",
  "title": "RunStateProjection",
  "type": "object",
  "required": ["thread_id", "status", "latest_seq", "provider", "attempts", "provider_attempts", "side_effects"],
  "properties": {
    "thread_id": { "type": "string" },
    "status": { "type": "string" },
    "prompt": { "type": "string" },
    "fixture": { "type": ["string", "null"] },
    "skill": { "type": ["object", "null"] },
    "workflow": { "type": ["object", "null"] },
    "provider": { "type": "object" },
    "model": { "type": ["string", "null"] },
    "fixture_fallback": { "type": "boolean" },
    "conversation_id": { "type": ["string", "null"] },
    "turn_id": { "type": ["string", "null"] },
    "user_message_id": { "type": ["string", "null"] },
    "assistant_message_id": { "type": ["string", "null"] },
    "transcript_status": { "type": ["string", "null"] },
    "active_head_message_id": { "type": ["string", "null"] },
    "branch_metadata": { "type": ["object", "null"] },
    "transcript_parts": { "type": "array", "items": { "type": "object" } },
    "compaction_summaries": { "type": "array", "items": { "$ref": "compaction-summary.schema.json" } },
    "tool_output_replacements": { "type": "array", "items": { "$ref": "tool-output-replacement.schema.json" } },
    "context_trace": { "type": ["object", "null"] },
    "audit_ids": { "type": "array", "items": { "type": "string" } },
    "permission_decisions": { "type": "array", "items": { "$ref": "permission-decision.schema.json" } },
    "doctor_status": { "type": ["string", "null"] },
    "trace_export_refs": { "type": "array", "items": { "type": "object" } },
    "latest_seq": { "type": "integer", "minimum": 0 },
    "failure_class": { "type": ["string", "null"] },
    "repair_required": { "type": "boolean" },
    "pending_interrupt": { "type": ["object", "null"] },
    "attempts": { "type": "array", "items": { "type": "object" } },
    "provider_attempts": { "type": "array", "items": { "type": "object" } },
    "side_effects": { "type": "array", "items": { "type": "object" } },
    "repair_notes": { "type": "array", "items": { "type": "object" } },
    "lock": { "type": ["object", "null"] },
    "checkpoints": { "type": "array", "items": { "type": "object" } }
  },
  "additionalProperties": true
}
